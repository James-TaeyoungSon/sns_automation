# ── OpenAI ──────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Threads (Meta) ───────────────────────
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=

# ── Google Blogger OAuth ──────────────────
# Google Cloud Console > 사용자 인증 정보 > OAuth 2.0 클라이언트 ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
BLOGGER_BLOG_URL=https://yourblog.blogspot.com

# ── 이미지 API ───────────────────────────
PEXELS_API_KEY=
PIXABAY_API_KEY=
IMGBB_API_KEY=

# ── 앱 설정 ─────────────────────────────
# 로컬: http://localhost:5000 / Render: https://your-app.onrender.com
APP_BASE_URL=http://localhost:5000
FLASK_SECRET_KEY=change-me-in-production
ADMIN_TOKEN=

# ── Notion ──────────────────────────────
# AI_project CLAUDE.md의 통합 토큰 사용
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_ARTICLES_DB_ID=323795a7282b802dac16e3a15ceb57f6

# ── Telegram 봇 ──────────────────────────
# 1. t.me/BotFather → /newbot → 토큰 발급
# 2. 봇에게 메시지 전송 후 t.me/userinfobot → Chat ID 확인
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── 스케줄 ──────────────────────────────
CRAWL_INTERVAL_HOURS=6    # 다이제스트 발송 간격 (시간)
AUTO_POST_HOUR=9          # 자동 발행 시각 KST (AUTO_POST_ENABLED=true 시)
AUTO_POST_ENABLED=false
DIGEST_ENABLED=true       # Telegram 다이제스트 활성화

# ── DB 경로 ─────────────────────────────
# 로컬: 기본값 (data/blog.db) / Render: /app/data/blog.db
# DB_PATH=/app/data/blog.db
